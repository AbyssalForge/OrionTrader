# Configuration PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=trading_data
POSTGRES_URL=your_postgres_url
POSTGRES_PORT=5432
# Prod uniquement (docker-compose.prod.yml) : hostname postgres vu par FastAPI
# Doit être "wg-easy" (après docker network connect oriontrader_network wg-easy)
POSTGRES_URL_VPN=wg-easy

# Configuration Airflow Database
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=your_airflow_password

# Configuration MLflow Database
MLFLOW_DB_NAME=mlflow
MLFLOW_DB_USER=mlflow
MLFLOW_DB_PASSWORD=your_mlflow_password

# Configuration FastAPI
FASTAPI_DB_DATA_NAME=trading_data
FASTAPI_DB_NAME=fastapi
FASTAPI_DB_USER=fastapi
FASTAPI_DB_PASSWORD=your_fastapi_password
FASTAPI_MASTER_TOKEN=your_master_token
API_KEY=your_api_key

# Configuration Streamlit
STREAMLIT_DB_USER=streamlit
STREAMLIT_DB_PASSWORD=your_streamlit_password

# Configuration PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# Configuration Vault
VAULT_ADDR=your_vault_url
VAULT_MOUNT=OrionTrader
VAULT_UNSEAL_KEY=your_unseal_key
VAULT_ROOT_TOKEN=your_root_token

# Configuration MetaTrader5 Pyro5 Server
# Par défaut, le serveur MT5 tourne sur la machine hôte Windows
# Depuis Docker, utilisez host.docker.internal pour accéder à l'hôte
MT5_HOST=host.docker.internal
MT5_PORT=9090

# Pyro5 Configuration
PYRO_HOST=0.0.0.0
PYRO_PORT=9092
PYRO_SERIALIZER=json

# Configuration MetaTrader5 (compte demo ou réel)
MT5_LOGIN=your_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=MetaQuotes-Demo

# VNC pour debug (optionnel)
ENABLE_VNC=true

# Discord (notifications pipeline)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url

# MLflow
MLFLOW_TRACKING_URI=your_mlflow_url
